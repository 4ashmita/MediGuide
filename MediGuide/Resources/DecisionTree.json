      "options": [
        { "text": "High fever", "symptomId": "high_fever", "next": "onset_check" },
        { "text": "Nausea or vomiting", "symptomId": "nausea", "next": "onset_check" },
        { "text": "Dizziness or lightheadedness", "symptomId": "dizziness", "next": "onset_check" },
        { "text": "Headache", "symptomId": "mild_headache", "next": "onset_check" }
      ]
    },

    "onset_check": {
      "id": "onset_check",
