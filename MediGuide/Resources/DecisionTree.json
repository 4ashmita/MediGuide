        { "text": "Unconscious or will not wake up", "symptomId": "unconscious", "next": "result" },
        { "text": "Seizure (convulsions)", "symptomId": "seizure", "next": "result" },
        { "text": "Stroke symptoms (face drooping, arm weakness, slurred speech)", "symptomId": "stroke_symptoms", "next": "result" },
        { "text": "Confusion or disorientation", "symptomId": "confusion", "next": "onset_check" }
      ]
    },

    "injury_allergic": {
      "id": "injury_allergic",
      "question": "Which best describes the situation?",
      "options": [
        { "text": "Severe or uncontrolled bleeding", "symptomId": "severe_bleeding", "next": "result" },
