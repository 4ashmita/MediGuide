        { "text": "Heart condition", "modifierId": "heart_condition", "next": "worsening_check" },
        { "text": "Weakened immune system", "modifierId": "immunocompromised", "next": "worsening_check" },
        { "text": "None of these", "next": "worsening_check" }
      ]
    },

    "worsening_check": {
      "id": "worsening_check",
      "question": "How are your symptoms progressing?",
      "options": [
        { "text": "Getting worse", "modifierId": "getting_worse", "next": "result" },
        { "text": "Staying about the same", "next": "result" },
        { "text": "Slowly improving", "next": "result" }
      ]
    },

    "infant_start": {
      "id": "infant_start",
      "question": "How old is the baby?",
      "options": [
        { "text": "Under 3 months", "next": "newborn_path" },
