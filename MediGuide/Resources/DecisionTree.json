        { "text": "Infant under 2", "ageGroupId": "infant", "modifierId": "age_under_2", "next": "infant_start" },
        { "text": "Child 2 to 12", "ageGroupId": "child", "next": "child_start" },
        { "text": "Adult 13 to 64", "ageGroupId": "adult", "next": "adult_start" },
        { "text": "Elderly 65 or older", "ageGroupId": "elderly", "modifierId": "age_over_65", "next": "elderly_start" }
      ]
    },

    "adult_start": {
      "id": "adult_start",
      "question": "What is your main concern right now?",
      "options": [
        { "text": "Chest pain or breathing difficulty", "next": "chest_breathing" },
        { "text": "Head, brain or neurological", "next": "head_neuro" },
        { "text": "Severe bleeding or allergic reaction", "next": "injury_allergic" },
        { "text": "General illness (fever, nausea, dizziness)", "next": "general_illness" }
      ]
    },

    "chest_breathing": {
      "id": "chest_breathing",
      "question": "Which best describes what you are feeling?",
      "options": [
        { "text": "Chest pain or pressure", "symptomId": "chest_pain", "next": "onset_check" },
        { "text": "Cannot breathe or very short of breath", "symptomId": "difficulty_breathing", "next": "result" },
        { "text": "Heart racing or pounding", "symptomId": "rapid_heartrate", "next": "onset_check" },
        { "text": "Low oxygen reading (below 95%)", "symptomId": "low_oxygen", "next": "condition_check" }
      ]
    },

    "head_neuro": {
      "id": "head_neuro",
      "question": "Which best describes what you are experiencing?",
